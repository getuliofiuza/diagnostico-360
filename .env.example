# ============================================================================
# DIAGNÓSTICO 360° - VARIÁVEIS DE AMBIENTE
# ============================================================================

# SUPABASE
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# DATABASE (se não usar Supabase)
# DATABASE_URL=postgresql://user:password@localhost:5432/diagnostico_360

# NEXTAUTH (se integrado com autenticação)
# NEXTAUTH_SECRET=your_secret_key_here
# NEXTAUTH_URL=http://localhost:3000

# APP
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# INTEGRAÇÃO COM NEUROCORP 360
# NEUROCORP_API_URL=https://api.neurocorp360.com.br
# NEUROCORP_API_KEY=your_api_key_here

# STORAGE (para arquivos/PDFs)
# STORAGE_BUCKET=diagnosticos-360
# STORAGE_REGION=us-east-1

# LOGGING
# LOG_LEVEL=debug
